# Переменные окружения для @SveklovBot

# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Имя бота без @
BOT_USERNAME=SveklovBot

# Perplexity API Key (https://www.perplexity.ai/settings/api)
PERPLEXITY_API_KEY=pplx-your_api_key_here

# Модель Perplexity (sonar — самая дешёвая)
PERPLEXITY_MODEL=sonar

# Системный промпт
SYSTEM_PROMPT=Ты — полезный ИИ-ассистент. Отвечай кратко, точно и по делу на языке вопроса.

# Максимум токенов в ответе
MAX_TOKENS=1024
