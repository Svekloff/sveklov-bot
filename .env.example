# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Perplexity API Key (get from https://docs.perplexity.ai)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Perplexity model (sonar, sonar-pro, sonar-reasoning-pro)
PERPLEXITY_MODEL=sonar-pro

# System prompt — personality of the bot
SYSTEM_PROMPT=Ты — умный AI-ассистент в Telegram. Отвечай кратко, по делу и на языке вопроса. Используй актуальную информацию из интернета. Если есть источники — укажи их.

# Max tokens in response
MAX_TOKENS=1024

# Bot username without @ (used for mention detection)
BOT_USERNAME=SveklovBot
