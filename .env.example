# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username_without_at

# Perplexity
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Owner Telegram ID (numeric)
OWNER_ID=123456789

# Optional
WHISPER_MODEL=base
MAX_HISTORY=10
GROUPS_FILE=groups.json

# System prompts (optional overrides)
# BUSINESS_SYSTEM_PROMPT=You are a helpful business assistant.
# GROUP_SYSTEM_PROMPT=You are a helpful assistant in a group chat.
